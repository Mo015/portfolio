      .grid {
        grid-template-columns: 1fr;
        gap: 20px;
      }
      
      .project-gallery {
        grid-template-columns: repeat(2, 1fr);
      }
      
      h1 {
        font-size: 2.2rem;
      }
      
      h2 {
        font-size: 1.8rem;
      }
    }

    @media (max-width: 480px) {
      header {
        padding: 40px 5%;
      }
      
      .profile-image {
        width: 120px;
        height: 120px;
      }
      
      h1 {
        font-size: 1.8rem;
      }
      
      h2 {
        font-size: 1.5rem;
      }
      
      .project-gallery {
        grid-template-columns: 1fr;
      }
      
      .card {
        padding: 20px;
      }
    }
  </style>
</head>
